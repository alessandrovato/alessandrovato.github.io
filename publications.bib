@article{Xie:2022,
	title = {Automated intraoperative central sulcus localization and somatotopic mapping using median nerve stimulation},
	volume = {19},
	issn = {1741-2560, 1741-2552},
	url = {https://iopscience.iop.org/article/10.1088/1741-2552/ac7dfd},
	doi = {10.1088/1741-2552/ac7dfd},
	abstract = {Objective. Accurate identification of functional cortical regions is essential in neurological resection. The central sulcus ({CS}) is an important landmark that delineates functional cortical regions. Median nerve stimulation ({MNS}) is a standard procedure to identify the position of the {CS} intraoperatively. In this paper, we introduce an automated procedure that uses {MNS} to rapidly localize the {CS} and create functional somatotopic maps. Approach. We recorded electrocorticographic signals from 13 patients who underwent {MNS} in the course of an awake craniotomy. We analyzed these signals to develop an automated procedure that determines the location of the {CS} and that also produces functional somatotopic maps. Main results. The comparison between our automated method and visual inspection performed by the neurosurgeon shows that our procedure has a high sensitivity (89\%) in identifying the {CS}. Further, we found substantial concordance between the functional somatotopic maps generated by our method and passive functional mapping (92\% sensitivity). Significance. Our automated {MNS}-based method can rapidly localize the {CS} and create functional somatotopic maps without imposing additional burden on the clinical procedure. With additional development and validation, our method may lead to a diagnostic tool that guides neurosurgeons and reduces postoperative morbidity in patients undergoing resective brain surgery.},
	pages = {046020},
	number = {4},
	journaltitle = {Journal of Neural Engineering},
	shortjournal = {J. Neural Eng.},
	author = {Xie, Tao and Wu, Zehan and Schalk, Gerwin and Tong, Yusheng and Vato, Alessandro and Raviv, Nataly and Guo, Qinglong and Ye, Huanpeng and Sheng, Xinjun and Zhu, Xiangyang and Brunner, Peter and Chen, Liang},
	urldate = {2023-03-03},
	date = {2022-08-01},
	langid = {english},
}

@article{Putzolu:2022,
	title = {Neural oscillations during motor imagery of complex gait: an HdEEG study},
	volume = {12},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-022-07511-x},
	doi = {10.1038/s41598-022-07511-x},
	shorttitle = {Neural oscillations during motor imagery of complex gait},
	abstract = {Abstract
            The aim of this study was to investigate differences between usual and complex gait motor imagery ({MI}) task in healthy subjects using high-density electroencephalography ({hdEEG}) with a {MI} protocol. We characterized the spatial distribution of α- and β-bands oscillations extracted from {hdEEG} signals recorded during {MI} of usual walking ({UW}) and walking by avoiding an obstacle (Dual-Task, {DT}). We applied a source localization algorithm to brain regions selected from a large cortical-subcortical network, and then we analyzed α and β bands Event-Related Desynchronizations ({ERDs}). Nineteen healthy subjects visually imagined walking on a path with ({DT}) and without ({UW}) obstacles. Results showed in both gait {MI} tasks, α- and β-band {ERDs} in a large cortical-subcortical network encompassing mostly frontal and parietal regions. In most of the regions, we found α- and β-band {ERDs} in the {DT} compared with the {UW} condition. Finally, in the β band, significant correlations emerged between {ERDs} and scores in imagery ability tests. Overall we detected {MI} gait-related α- and β-band oscillations in cortical and subcortical areas and significant differences between {UW} and {DT} {MI} conditions. A better understanding of gait neural correlates may lead to a better knowledge of pathophysiology of gait disturbances in neurological diseases.},
	pages = {4314},
	number = {1},
	journaltitle = {Scientific Reports},
	shortjournal = {Sci Rep},
	author = {Putzolu, Martina and Samogin, Jessica and Cosentino, Carola and Mezzarobba, Susanna and Bonassi, Gaia and Lagravinese, Giovanna and Vato, Alessandro and Mantini, Dante and Avanzino, Laura and Pelosin, Elisa},
	urldate = {2022-04-18},
	date = {2022-12},
	langid = {english},
	keywords = {Brain Oscillations, Motor Imagery, Gait},
}

@article{Putzolu:2024,
	title = {Motor imagery ability scores are related to cortical activation during gait imagery},
	volume = {14},
	issn = {2045-2322},
	doi = {10.1038/s41598-024-54966-1},
	abstract = {Motor imagery ({MI}) is the mental execution of actions without overt movements that depends on the ability to imagine. We explored whether this ability could be related to the cortical activity of the brain areas involved in the {MI} network. To this goal, brain activity was recorded using high-density electroencephalography in nineteen healthy adults while visually imagining walking on a straight path. We extracted Event-Related Desynchronizations ({ERDs}) in the θ, α, and β band, and we measured {MI} ability via (i) the Kinesthetic and Visual Imagery Questionnaire ({KVIQ}), (ii) the Vividness of Movement Imagery Questionnaire-2 ({VMIQ}), and (iii) the Imagery Ability ({IA}) score. We then used Pearson’s and Spearman’s coefficients to correlate {MI} ability scores and average {ERD} power ({avgERD}). Positive correlations were identified between {VMIQ} and {avgERD} of the middle cingulum in the β band and with {avgERD} of the left insula, right precentral area, and right middle occipital region in the θ band. Stronger activation of the {MI} network was related to better scores of {MI} ability evaluations, supporting the importance of testing {MI} ability during {MI} protocols. This result will help to understand {MI} mechanisms and develop personalized {MI} treatments for patients with neurological dysfunctions.},
	pages = {5207},
	journaltitle = {Scientific Reports},
	shortjournal = {Sci Rep},
	author = {Putzolu, Martina and Samogin, Jessica and Bonassi, Gaia and Cosentino, Carola and Mezzarobba, Susanna and Botta, Alessandro and Avanzino, Laura and Mantini, Dante and Vato, Alessandro and Pelosin, Elisa},
	urldate = {2024-03-18},
	date = {2024-03-03},
	file = {PubMed Central Full Text PDF:/Users/vato/Zotero/storage/6MQ7R2CR/Putzolu et al. - 2024 - Motor imagery ability scores are related to cortic.pdf:application/pdf},
	image	= {https://alessandrovato.github.io/assets/images/papers/SciRep2024.png},
}


